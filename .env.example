# OpenRouter API Key (Get your free/paid key from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM Model Selection (OpenRouter provider model ID)
# Recommended free/affordable models:
# - google/gemini-2.0-flash-lite-preview-02-05:free
# - meta-llama/llama-3.3-70b-instruct
# - deepseek/deepseek-r1-distill-llama-70b
LLM_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free

# OpenRouter Base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Vector Database Persistence Directory
CHROMA_DB_DIR=./data/chroma_db

# Upload Directory
UPLOAD_DIR=./data/uploads

# RAG Settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RESULTS=4

# Server Configuration
HOST=0.0.0.0
PORT=8000
